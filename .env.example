# Copy this file to .env.local for local development.
# Set these variables in the Vercel project dashboard for production.

# Site base URL — set to your production domain on Vercel
NEXT_PUBLIC_URL=https://www.thepropertymarketer.com

# WhatsApp number — full international format, digits only (no + or spaces)
NEXT_PUBLIC_WHATSAPP_NUMBER=263783580470

# Supabase — get these from your Supabase project settings
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
